library(arules)
crime_trans <- crime |>
  select(Type, Police_Station) |>
  lapply(as.factor) |>
  as("transactions")
crime_trans <- as(crime_trans, "transactions")
rules <- apriori(crime_trans, parameter = list(supp = 0.001, conf = 0.1, minlen=2, maxlen=5))
inspect(rules[1:10])
