crime <-readxl::read_excel("C:/DM/crime_data_bengaluru.xlsx")
#Pre process
colSums(is.na(crime))
crime <- crime[rowSums(is.na(crime)) !=ncol(crime),]
crime$`Police Station`[is.na(crime$`Police Station`)] <- "Unknown"
crime$Type[is.na(crime$Type)] <- "Unsepcified"
crime$Place[is.na(crime$Place)] <- "Unknown"
crime$Latitude[is.na(crime$Latitude)] <- mean(crime$Latitude,na.rm = TRUE)
crime$Longitude[is.na(crime$Longitude)] <- mean(crime$Longitude,na.rm = TRUE)
crime$Date <- as.Date(as.numeric(crime$Date),origin = "1899-12-30")
crime$Time <- as.numeric(crime$Time)
crime$Time <- format(as.POSIXct(crime$Time * 86400, origin="1970-01-01",tz="UTC"),"%H:%M")
crime <- unique(crime)
crime$Latitude <- as.numeric(crime$Latitude)
crime$Longitude <- as.numeric(crime$Longitude)

crime <- crime[crime$Latitude>= -90 & crime$Latitude<=90 ,]
crime <- crime[crime$Longitude>= -180 & crime$Longitude<=180 ,]
crime <- na.omit(crime)
writexl::write_xlsx(crime,"crime_cleaned.xlsx")
colnames(crime)[colnames(crime)== "Police Station"] <- "Police_Station"
library(dplyr)
library(ggplot2)
p <- crime |>
  group_by(Year ,Type) |>
  summarise(count = n(), .groups="drop") |>
  ggplot(aes(x = Year, y = count, fill = Type)) +
  geom_col(position = "dodge") + theme_minimal() + labs(title=" Year wise crime trend" ,x="Year",y="Number of crimes",fill="Crime type")
windows()
print(p)


